{
    "name": "denoiser",
    "description": "OIDN denoiser for the web, running fully on WebGPU via onnxruntime-web",
    "keywords": [
        "OIDN",
        "denoise",
        "denoiser",
        "unet",
        "webgpu",
        "onnx",
        "onnxruntime"
    ],
    "version": "2.0.0-alpha.0",
    "author": "Dennis Smolek",
    "contributors": [
        "Dennis Smolek"
    ],
    "license": "MIT",
    "homepage": "https://github.com/pmndrs/denoiser",
    "bugs": {
        "url": "https://github.com/pmndrs/denoiser/issues"
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist/**",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "test": "vitest run --coverage",
        "build": "tsc && rollup --config rollup.config.mjs",
        "format": "prettier --write ."
    },
    "devDependencies": {
        "@rollup/plugin-commonjs": "^29.0.3",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-typescript": "^12.3.0",
        "@typescript-eslint/eslint-plugin": "^8.63.0",
        "@typescript-eslint/parser": "^8.63.0",
        "@webgpu/types": "^0.1.71",
        "eslint": "^10.6.0",
        "prettier": "^3.9.5",
        "rollup": "^4.62.2",
        "rollup-plugin-copy": "^3.5.0",
        "tslib": "^2.8.1",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "onnxruntime-web": "^1.27.0"
    }
}
