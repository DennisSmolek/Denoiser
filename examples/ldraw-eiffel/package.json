    "three-mesh-bvh": "^0.9.9",
    "xatlas-web": "^0.1.0"
  },
  "devDependencies": {
    "onnxruntime-web": "^1.27.0",
    "typescript": "^5.5.2",
    "vite": "^5.4.0"
  }
